<?xml version="1.0" encoding="utf-8"?>
<browserconfig>
  <msapplication>
    <tile>
      <square70x70logo src="/assets/icons/icon-72.png"/>
      <square150x150logo src="/assets/icons/icon-144.png"/>
      <wide310x150logo src="/assets/icons/wide-310x150.png"/>
      <square310x310logo src="/assets/icons/icon-310.png"/>
      <TileColor>#0d1117</TileColor>
    </tile>
    <notification>
      <polling-uri src="/notifications.xml"/>
      <frequency>30</frequency>
      <cycle>1</cycle>
    </notification>
    <badge>
      <polling-uri src="/badge.xml"/>
      <frequency>30</frequency>
    </badge>
  </msapplication>
</browserconfig>
